# Copy this file to .env.local and fill in local values.
# Never commit real API keys, passwords, tokens, or private email addresses.

# AI provider selection: mock | openclaw | openai-compatible | anthropic
AI_PROVIDER=mock

# OpenClaw / OpenAI-compatible provider
OPENCLAW_BASE_URL=https://example.openclaw.ai/v1
OPENCLAW_API_KEY=
OPENCLAW_MODEL=

# Generic OpenAI-compatible provider
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Anthropic / Claude provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Local-first database
DATABASE_URL=file:./dev-mvp.db

# Enable only when the app is served through HTTPS. Keep false for LAN HTTP.
COOKIE_SECURE=false

# Session and saved-AI encryption secrets. APP_ENCRYPTION_KEY is optional but recommended in production.
SESSION_SECRET=change-this-local-secret
APP_ENCRYPTION_KEY=

# Keep false unless this host intentionally connects to a LAN/localhost AI service.
AI_ALLOW_PRIVATE_ENDPOINTS=false

# Optional local seed owner account overrides.
# Defaults in development: admin@debate.local / debate-admin-2026
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=
SEED_ADMIN_PASSWORD=
